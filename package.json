{
  "name": "builder-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:ai-surfaces": "node scripts/generate-ai-surfaces.js",
    "generate:algolia-synonyms": "node scripts/generate-algolia-synonyms.js",
    "generate:bespoke-host-pages": "node scripts/generate-bespoke-host-pages.js",
    "bootstrap:i18n": "node scripts/bootstrap-i18n.js",
    "bootstrap:i18n:reseed": "node scripts/bootstrap-i18n.js --reseed",
    "bootstrap:i18n:ru": "node scripts/bootstrap-ru-i18n.js",
    "bootstrap:i18n:ru:reseed": "node scripts/bootstrap-ru-i18n.js --reseed",
    "submit:indexnow": "node scripts/submit-indexnow.js",
    "submit:indexnow:dry-run": "node scripts/submit-indexnow.js --dry-run",
    "docusaurus": "docusaurus",
    "start": "yarn generate:bespoke-host-pages && docusaurus build && docusaurus serve",
    "start:full": "yarn generate:ai-surfaces && yarn generate:bespoke-host-pages && docusaurus build && docusaurus serve",
    "start:dev": "yarn generate:bespoke-host-pages && docusaurus start",
    "start:dev:ru": "yarn generate:bespoke-host-pages && docusaurus start --locale ru",
    "build": "yarn generate:ai-surfaces && yarn generate:bespoke-host-pages && docusaurus build",
    "audit:page-models": "node scripts/audit-generated-page-models.js",
    "audit:i18n": "node scripts/audit-i18n.js",
    "audit:i18n:all": "node scripts/audit-i18n.js --all-locales --wave 1",
    "audit:i18n:ru": "node scripts/audit-ru-translation.js",
    "audit:ru-terminology": "node scripts/audit-ru-terminology.js",
    "audit:indexing": "yarn audit:page-models && yarn build && node scripts/audit-indexing-surface.js",
    "audit:algolia-highlights": "node scripts/audit-algolia-highlights.js",
    "audit:algolia-relevance": "node scripts/audit-algolia-relevance.js",
    "algolia:inspect": "node scripts/algolia-inspect.js",
    "algolia:status": "node scripts/algolia-status.js",
    "algolia:sync": "node scripts/algolia-sync.js",
    "algolia:crawler:status": "node scripts/algolia-crawler-status.js",
    "algolia:crawler:sync": "node scripts/algolia-crawler-sync.js",
    "algolia:crawler:start": "node scripts/algolia-crawler-start.js",
    "algolia:crawler:wait": "node scripts/algolia-crawler-wait.js",
    "ci:locale-quality": "yarn audit:ru-terminology && yarn audit:i18n:all && yarn build && node scripts/audit-indexing-surface.js",
    "playwright:install": "env -u NO_COLOR playwright install chromium",
    "swizzle": "docusaurus swizzle",
    "deploy": "yarn generate:ai-surfaces && yarn generate:bespoke-host-pages && docusaurus deploy && yarn submit:indexnow",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:headed": "env -u NO_COLOR playwright test --headed",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@algolia/client-search": "5.49.0",
    "@docsearch/docusaurus-adapter": "^4.6.2",
    "@docusaurus/core": "3.10.0",
    "@docusaurus/plugin-client-redirects": "3.10.0",
    "@docusaurus/plugin-content-docs": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/theme-common": "3.10.0",
    "@docusaurus/theme-mermaid": "3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@fastnear/api": "^0.9.7",
    "@mdx-js/react": "^3.1.1",
    "algoliasearch": "5.49.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "search-insights": "^2.17.3",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "js-yaml": "^4.1.1"
  },
  "resolutions": {
    "dompurify": "^3.3.2",
    "tar": "^7.5.11",
    "follow-redirects": "^1.16.0",
    "picomatch@npm:^4.0.3": "^4.0.4",
    "picomatch@npm:^2.0.4": "^2.3.2",
    "picomatch@npm:^2.2.1": "^2.3.2",
    "picomatch@npm:^2.2.3": "^2.3.2",
    "picomatch@npm:^2.3.1": "^2.3.2",
    "minimatch@npm:^10.2.2": "^10.2.3",
    "minimatch@npm:3.1.2": "3.1.5",
    "brace-expansion@npm:^5.0.2": "^5.0.5",
    "brace-expansion@npm:^1.1.7": "^1.1.13",
    "path-to-regexp@npm:~0.1.12": "^0.1.13",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "svgo@npm:^3.0.2": "^3.3.3",
    "svgo@npm:^3.2.0": "^3.3.3",
    "serialize-javascript@npm:^6.0.0": "^7.0.5",
    "serialize-javascript@npm:^6.0.1": "^7.0.5",
    "serialize-javascript@npm:^6.0.2": "^7.0.5"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "yarn@4.9.2"
}
