# Build target
NODE_ENV=production

# Search provider
DOCS_SEARCH_PROVIDER=algolia

# Runtime DocSearch credentials used by the docs site
DOCSEARCH_APP_ID=YOUR_ALGOLIA_APP_ID
DOCSEARCH_API_KEY=YOUR_ALGOLIA_SEARCH_ONLY_API_KEY
# This should match the crawler action's indexName in Algolia, not the crawler display name.
DOCSEARCH_INDEX_NAME=YOUR_DOCSEARCH_INDEX_NAME

# Operator-only Algolia crawler credentials for yarn algolia:status, yarn algolia:sync,
# and the explicit crawler control commands.
ALGOLIA_CRAWLER_USER_ID=YOUR_ALGOLIA_CRAWLER_USER_ID
ALGOLIA_CRAWLER_API_KEY=YOUR_ALGOLIA_CRAWLER_API_KEY
ALGOLIA_CRAWLER_NAME=YOUR_ALGOLIA_CRAWLER_NAME

# Optional feature flag for hiding early-access API families from the UI and sitemap.
# HIDE_EARLY_API_FAMILIES=true

# Optional Cloudflare Web Analytics beacon. When set, injects the
# static.cloudflareinsights.com/beacon.min.js script on every page with this
# site token. Absent token = no beacon (dev-friendly).
# CF_ANALYTICS_TOKEN=YOUR_CLOUDFLARE_WEB_ANALYTICS_TOKEN
